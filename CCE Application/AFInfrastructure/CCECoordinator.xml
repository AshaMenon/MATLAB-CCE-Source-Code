    <Description>Execution Mode of a Coordinator</Description>
    <AFEnumerationValue>
      <Name>Cyclic</Name>
      <Value>1</Value>
      <Description>Runs repeated cycles every ExecutionPeriod seconds until Lifetime is reached, then exits</Description>
    </AFEnumerationValue>
    <AFEnumerationValue>
